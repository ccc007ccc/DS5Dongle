diff --git a/celt/celt_encoder.c b/celt/celt_encoder.c
--- a/celt/celt_encoder.c
+++ b/celt/celt_encoder.c
@@ -1111 +1111 @@ static int patch_transient_decision(opus_val16 *newE, opus_val16 *oldE, int nbEBa
-static int run_prefilter(CELTEncoder *st, celt_sig *in, celt_sig *prefilter_mem, int CC, int N,
+static __attribute__((noinline)) int run_prefilter(CELTEncoder *st, celt_sig *in, celt_sig *prefilter_mem, int CC, int N,
@@ -1127,0 +1128,33 @@ static int run_prefilter(CELTEncoder *st, celt_sig *in, celt_sig *prefilter_mem,
+
+   /* Complexity 0-4 disables pitch analysis. When the previous gain is also
+      zero, comb_filter is an identity transform, so avoid constructing the
+      temporary pre[] window and running the zero-gain filter. Keep every
+      history buffer identical so raising complexity later remains valid. */
+   if (!enabled && st->prefilter_gain == 0)
+   {
+      c = 0; do {
+         celt_sig *in_c = in + c*(N+overlap);
+         celt_sig *mem_c = prefilter_mem + c*COMBFILTER_MAXPERIOD;
+
+         st->prefilter_period = IMAX(st->prefilter_period,
+               COMBFILTER_MINPERIOD);
+         OPUS_COPY(in_c, st->in_mem+c*overlap, overlap);
+         OPUS_COPY(st->in_mem+c*overlap, in_c+N, overlap);
+
+         if (N > COMBFILTER_MAXPERIOD)
+         {
+            OPUS_COPY(mem_c,
+                  in_c+overlap+N-COMBFILTER_MAXPERIOD,
+                  COMBFILTER_MAXPERIOD);
+         } else {
+            OPUS_MOVE(mem_c, mem_c+N, COMBFILTER_MAXPERIOD-N);
+            OPUS_COPY(mem_c+COMBFILTER_MAXPERIOD-N, in_c+overlap, N);
+         }
+      } while (++c < CC);
+
+      *gain = 0;
+      *pitch = COMBFILTER_MINPERIOD;
+      *qgain = 0;
+      RESTORE_STACK;
+      return 0;
+   }
