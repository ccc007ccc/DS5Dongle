diff --git a/celt/fixed_generic.h b/celt/fixed_generic.h
--- a/celt/fixed_generic.h
+++ b/celt/fixed_generic.h
@@ -68,7 +68,25 @@
 #endif
 
 /** 16x32 multiplication, followed by a 15-bit shift right. Results fits in 32 bits */
-#if OPUS_FAST_INT64
+#if defined(M61_OPUS_E907_Q15_KMMWB2)
+static OPUS_INLINE opus_val32 m61_opus_e907_mult16_32_q15(opus_val16 a,
+                                                          opus_val32 b)
+{
+#if defined(__riscv)
+   opus_val32 result;
+   /* KMMWB2 saturates only for INT32_MIN * INT16_MIN. That mathematical
+      result is +2^31 and is outside this macro's documented result domain. */
+   __asm__ volatile("kmmwb2 %0, %1, %2"
+                    : "=r"(result)
+                    : "r"(b), "r"((opus_val32)a));
+   return result;
+#else
+   return (opus_val32)(((opus_int64)a * b) >> 15);
+#endif
+}
+#define MULT16_32_Q15(a,b) \
+   (m61_opus_e907_mult16_32_q15((opus_val16)(a), (opus_val32)(b)))
+#elif OPUS_FAST_INT64
 #define MULT16_32_Q15(a,b) ((opus_val32)SHR((opus_int64)((opus_val16)(a))*(b),15))
 #else
 #define MULT16_32_Q15(a,b) ADD32(SHL(MULT16_16((a),SHR((b),16)),1), SHR(MULT16_16SU((a),((b)&0x0000ffff)),15))
