 #   define S_MUL(a,b) MULT16_32_Q15(b, a)
 
+#if defined(M61_OPUS_E907_FFT_COMPLEX_MAC) && defined(__riscv)
+static OPUS_INLINE opus_uint32 m61_fft_pack_twiddle(kiss_twiddle_cpx value)
+{
+   opus_uint32 packed;
+   __builtin_memcpy(&packed, &value, sizeof(packed));
+   return packed;
+}
+
+static OPUS_INLINE opus_val32 m61_fft_mul_bottom(opus_val32 value, opus_uint32 twiddle)
+{
+   opus_val32 result;
+   __asm__ volatile("kmmwb2 %0, %1, %2" : "=r"(result) : "r"(value), "r"(twiddle));
+   return result;
+}
+
+static OPUS_INLINE opus_val32 m61_fft_mul_top(opus_val32 value, opus_uint32 twiddle)
+{
+   opus_val32 result;
+   __asm__ volatile("kmmwt2 %0, %1, %2" : "=r"(result) : "r"(value), "r"(twiddle));
+   return result;
+}
+
+static OPUS_INLINE opus_val32 m61_fft_mac_bottom(opus_val32 accumulator,
+                                                 opus_val32 value,
+                                                 opus_uint32 twiddle)
+{
+   __asm__ volatile("kmmawb2 %0, %1, %2" : "+r"(accumulator) : "r"(value), "r"(twiddle));
+   return accumulator;
+}
+
+static OPUS_INLINE opus_val32 m61_fft_mac_top(opus_val32 accumulator,
+                                              opus_val32 value,
+                                              opus_uint32 twiddle)
+{
+   __asm__ volatile("kmmawt2 %0, %1, %2" : "+r"(accumulator) : "r"(value), "r"(twiddle));
+   return accumulator;
+}
+
+#define C_MUL(m,a,b) do { \
+   opus_uint32 m61_tw = m61_fft_pack_twiddle(b); \
+   (m).r = m61_fft_mac_top(m61_fft_mul_bottom((a).r, m61_tw), \
+                           NEG32_ovflw((a).i), m61_tw); \
+   (m).i = m61_fft_mac_bottom(m61_fft_mul_top((a).r, m61_tw), \
+                              (a).i, m61_tw); \
+} while (0)
+
+#define C_MULC(m,a,b) do { \
+   opus_uint32 m61_tw = m61_fft_pack_twiddle(b); \
+   (m).r = m61_fft_mac_top(m61_fft_mul_bottom((a).r, m61_tw), (a).i, m61_tw); \
+   (m).i = m61_fft_mac_top(m61_fft_mul_bottom((a).i, m61_tw), \
+                           NEG32_ovflw((a).r), m61_tw); \
+} while (0)
+#else
