diff --git a/src/opus_decoder.c b/src/opus_decoder.c
index 331f861..9f369ea 100644
--- a/src/opus_decoder.c
+++ b/src/opus_decoder.c
@@ -628,14 +628,33 @@ int opus_decode_native(OpusDecoder *st, const unsigned char *data,
    } else if (len<0)
       return OPUS_BAD_ARG;
 
+#if defined(M61_OPUS_DUALSENSE_D4_FASTPATH)
+   /* DualSense mic packets observed on the production link are a single
+      10 ms stereo CELT/SWB frame with TOC 0xD4 and 70 payload bytes. Keep
+      every other legal Opus packet on the upstream parser path. */
+   if (!decode_fec && !self_delimited && packet_offset == NULL &&
+       len == 71 && data[0] == 0xD4 && st->Fs == 48000 && frame_size >= 480)
+   {
+      packet_mode = MODE_CELT_ONLY;
+      packet_bandwidth = OPUS_BANDWIDTH_SUPERWIDEBAND;
+      packet_frame_size = 480;
+      packet_stream_channels = 2;
+      count = 1;
+      toc = 0xD4;
+      size[0] = 70;
+      offset = 1;
+   } else
+#endif
+   {
    packet_mode = opus_packet_get_mode(data);
    packet_bandwidth = opus_packet_get_bandwidth(data);
    packet_frame_size = opus_packet_get_samples_per_frame(data, st->Fs);
    packet_stream_channels = opus_packet_get_nb_channels(data);
 
    count = opus_packet_parse_impl(data, len, self_delimited, &toc, NULL,
                                   size, &offset, packet_offset);
    if (count<0)
       return count;
+   }
 
    data += offset;
 
