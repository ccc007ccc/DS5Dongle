diff --git a/celt/mathops.c b/celt/mathops.c
--- a/celt/mathops.c
+++ b/celt/mathops.c
@@ -178,7 +178,24 @@ opus_val16 celt_cos_norm(opus_val32 x)
 
 /** Reciprocal approximation (Q15 input, Q16 output) */
+#if defined(M61_OPUS_E907_EXACT_RCP)
+__attribute__((noinline))
+#endif
 opus_val32 celt_rcp(opus_val32 x)
 {
+#if defined(M61_OPUS_E907_EXACT_RCP)
+   opus_uint32 result;
+   celt_assert2(x>0, "celt_rcp() only defined for positive values");
+   if (x == 1)
+      return 2147483647;
+# if defined(__riscv)
+   __asm__ volatile("divu %0, %1, %2"
+                    : "=r"(result)
+                    : "r"(0x80000000U), "r"((opus_uint32)x));
+# else
+   result = 0x80000000U / (opus_uint32)x;
+# endif
+   return (opus_val32)result;
+#else
    int i;
    opus_val16 n;
    opus_val16 r;
@@ -203,5 +220,6 @@ opus_val32 celt_rcp(opus_val32 x)
        error of 1.24665/32768. */
    return VSHR32(EXTEND32(r),i-16);
+#endif
 }
 
 #endif
