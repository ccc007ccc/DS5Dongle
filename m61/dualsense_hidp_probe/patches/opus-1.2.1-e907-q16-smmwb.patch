diff --git a/celt/fixed_generic.h b/celt/fixed_generic.h
--- a/celt/fixed_generic.h
+++ b/celt/fixed_generic.h
@@ -36,7 +36,24 @@
 #define MULT16_16SU(a,b) ((opus_val32)(opus_val16)(a)*(opus_val32)(opus_uint16)(b))
 
 /** 16x32 multiplication, followed by a 16-bit shift right. Results fits in 32 bits */
-#if OPUS_FAST_INT64
+#if defined(M61_OPUS_E907_Q16_SMMWB)
+static OPUS_INLINE opus_val32 m61_opus_e907_mult16_32_q16(opus_val16 a,
+                                                          opus_val32 b)
+{
+#if defined(__riscv)
+   opus_val32 result;
+   __asm__ volatile("smmwb %0, %1, %2"
+                    : "=r"(result)
+                    : "r"(b), "r"((opus_val32)a));
+   return result;
+#else
+   /* SMMWB returns bits 47:16 of signed word * signed low halfword. */
+   return (opus_val32)(((opus_int64)a * b) >> 16);
+#endif
+}
+#define MULT16_32_Q16(a,b) \
+   (m61_opus_e907_mult16_32_q16((opus_val16)(a), (opus_val32)(b)))
+#elif OPUS_FAST_INT64
 #define MULT16_32_Q16(a,b) ((opus_val32)SHR((opus_int64)((opus_val16)(a))*(b),16))
 #else
 #define MULT16_32_Q16(a,b) ADD32(MULT16_16((a),SHR((b),16)), SHR(MULT16_16SU((a),((b)&0x0000ffff)),16))
