# DS5Dongle dual-chip ESP32 coprocessor (BTstack host over VHCI)
CONFIG_DS5_DUAL_CHIP_SPI_COPROCESSOR=y
CONFIG_DS5_RAW_HIDP_AUTO_CONNECT=y
CONFIG_DS5_DUAL_CHIP_TX_QUEUE_DEPTH=4
CONFIG_DS5_DUAL_CHIP_RESPONSE_QUEUE_DEPTH=8

# Bluetooth: controller-only, BTstack talks VHCI
CONFIG_BT_ENABLED=y
CONFIG_BT_CONTROLLER_ONLY=y
CONFIG_BTDM_CTRL_MODE_BR_EDR_ONLY=y
CONFIG_BTDM_CTRL_MODE_BLE_ONLY=n
CONFIG_BTDM_CTRL_MODE_BTDM=n
