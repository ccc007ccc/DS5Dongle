menu "DS5 DualSense Bridge"

    choice DS5_BT_BACKEND
        prompt "Stage-1 Bluetooth backend"
        default DS5_BT_BACKEND_HIDH
        help
            Select how ESP32 connects to the real DualSense during stage 1.
            The ESP-IDF HID Host backend is the default because it is the
            first partially validated path. Raw HIDP opens Classic L2CAP HID
            Control/Interrupt PSMs directly and is intended for diagnosing or
            bypassing HID Host limitations when full 0x31 reports do not appear.

        config DS5_BT_BACKEND_HIDH
            bool "ESP-IDF HID Host API"

        config DS5_BT_BACKEND_RAW_HIDP
            bool "Raw Classic L2CAP HIDP probe"
            select BT_L2CAP_ENABLED
    endchoice

    config DS5_SCAN_SECONDS
        int "Classic Bluetooth inquiry duration, seconds"
        range 2 61
        default 30
        help
            Time spent scanning for a DualSense controller before retrying.

    config DS5_ACCEPT_ANY_GAMEPAD
        bool "Accept first discovered classic Bluetooth gamepad"
        default y
        help
            Keep this enabled during bring-up so a DualSense in pairing mode is
            accepted even if its EIR name is not resolved. Disable it if there
            are other Bluetooth gamepads nearby.

    config DS5_PRINT_RAW_REPORTS
        bool "Print raw HID reports"
        default n
        help
            Dumps each received HID interrupt report at debug level. This is
            useful for protocol investigation but too noisy for normal testing.

    config DS5_LOG_UNCHANGED_MS
        int "State heartbeat interval when inputs do not change"
        range 100 10000
        default 1000
        help
            Parsed input state is always printed when it changes. This interval
            controls the periodic heartbeat when the controller is idle.

    config DS5_BRINGUP_RETRIES
        int "DualSense full-report bring-up attempts"
        range 1 20
        default 8
        help
            Number of feature/output initialization attempts after HID connects.
            Keep this finite: if full 0x31 reports still do not appear, the log
            should show an exhausted bring-up path instead of spamming HID output.

    config DS5_BRINGUP_RETRY_MS
        int "DualSense bring-up retry interval, milliseconds"
        range 100 5000
        default 500
        help
            Delay between repeated DualSense feature/output initialization
            attempts while the controller is still sending only short reports.

    config DS5_LED_GREEN_GPIO
        int "Green status LED GPIO (-1 disables)"
        range -1 33
        default -1
        help
            GPIO for the controllable green status LED. Many ESP32-WROOM-32
            CH340 boards only have an always-on red power LED and a controllable
            blue GPIO2 LED; keep this at -1 if no green LED is wired to ESP32.

    config DS5_LED_RED_GPIO
        int "Red status LED GPIO (-1 disables)"
        range -1 33
        default -1
        help
            GPIO for a controllable red status LED. If configured, normal
            boot, Bluetooth connecting, and connected states drive it off.
            Keep this at -1 when the red LED is only a power LED tied to the
            board power rail.

    config DS5_LED_BLUE_GPIO
        int "Blue status LED GPIO (-1 disables)"
        range -1 33
        default 2
        help
            GPIO for the controllable blue status LED. GPIO2 is the common
            onboard blue LED on many ESP32-WROOM-32 development boards.

    config DS5_LED_ACTIVE_LOW
        bool "Status LEDs are active low"
        default n
        help
            Enable this if the status LEDs turn on when their GPIO is driven low.

    config DS5_LED_BLINK_MS
        int "Bluetooth connecting blink interval, milliseconds"
        range 100 2000
        default 250
        help
            Blue LED blink interval while scanning or connecting to DualSense.

endmenu
